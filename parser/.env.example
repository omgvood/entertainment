# --- Выбор LLM-провайдера ---
# gemini (по умолчанию) или groq. Можно временно переопределять через CLI --provider.
LLM_PROVIDER=gemini

# Дефолтные модели по провайдерам (можно переопределить):
#   gemini → gemini-2.5-flash-lite
#   groq   → llama-3.3-70b-versatile
# Эти переменные провайдер-специфичные, не путаются при --provider override.
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=llama-3.1-70b-versatile

# --- LLM-ключи (один обязательный по выбранному провайдеру) ---

# Google Gemini — https://aistudio.google.com → Get API key (free tier)
GEMINI_API_KEY=AIza...

# Groq — https://console.groq.com → API keys (free tier)
GROQ_API_KEY=gsk_...

# --- Supabase ---
SUPABASE_URL=https://taixlqbbepudndqhnehj.supabase.co
# service_role key (НЕ publishable!) — Settings → Data API → service_role → Reveal
# ВАЖНО: обходит RLS, никогда не коммитить.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- 2ГИС Catalog API ---
# Нужен только если в seeds.yaml есть direct_api источники (боулинг/бильярд/картинг)
# https://dev.2gis.com → Создать приложение
TWOGIS_API_KEY=

# --- Timepad API ---
# Нужен если в seeds.yaml есть direct_api источники с provider=timepad
# https://dev.timepad.ru -> Личный кабинет -> API -> Создать токен
TIMEPAD_TOKEN=

# --- VK ---
# Сервисный ключ mini-app (wall.get). Нужен для vk_posts и vk_events.
# https://vk.com/apps -> Создать приложение -> Standalone -> Настройки -> Сервисный ключ
VK_SERVICE_KEY=

# --- Прочее ---
LOG_LEVEL=INFO
